--- a/scripts/build/deps/webkit.ts
+++ b/scripts/build/deps/webkit.ts
@@ -330,7 +330,43 @@ export const webkit: Dependency = {
       PORT: "JSCOnly",
       ENABLE_STATIC_JSC: "ON",
       USE_THIN_ARCHIVES: "OFF",
-      ENABLE_FTL_JIT: "ON",
+      // PENRYN_BUILD_CLOOP=1: fall back to the portable CLoop
+      // interpreter instead of the JIT. Same WebKit option used
+      // upstream for CPU/platform combos that can't safely JIT (e.g.
+      // WPEWebKit's ARMv5/ARMv6 Buildroot config). Eliminates
+      // JIT-emitted machine code at runtime entirely, at a real perf
+      // cost — see docs/ARCHITECTURE.md ("layer 2") in the
+      // bun-penryn-port handoff package for why this exists. No-op
+      // unless set.
+      //
+      // NOT named BUN_JSC_* on purpose: Bun's own bootstrap binary
+      // treats any BUN_JSC_<name> env var as a runtime JSC engine
+      // option override (validated against JSC's OptionsList.h) and
+      // refuses to start at all if <name> isn't a real option — this
+      // is a CMake-configure-time build flag, not a JSC runtime
+      // option, and naming it BUN_JSC_CLOOP collided with that
+      // reserved namespace and broke the bootstrap binary itself
+      // before the build script ever ran. See docs/DECISIONS.md #15.
+      //
+      // ENABLE_SAMPLING_PROFILER and ENABLE_WEBASSEMBLY both hard-
+      // conflict with ENABLE_C_LOOP in WebKit's own CMake (checked
+      // every WEBKIT_OPTION_CONFLICT(... ENABLE_C_LOOP) rule directly
+      // in Source/cmake/WebKitFeatures.cmake rather than discovering
+      // them one at a time across separate failed runs — see
+      // docs/DECISIONS.md #16). Both are safe to drop for this
+      // JIT-less variant: losing the CPU sampling profiler and Wasm
+      // support doesn't affect plain JS execution, which is what this
+      // variant exists to test.
+      ...(process.env.PENRYN_BUILD_CLOOP === "1"
+        ? {
+            ENABLE_C_LOOP: "ON",
+            ENABLE_JIT: "OFF",
+            ENABLE_DFG_JIT: "OFF",
+            ENABLE_FTL_JIT: "OFF",
+            ENABLE_SAMPLING_PROFILER: "OFF",
+            ENABLE_WEBASSEMBLY: "OFF",
+          }
+        : { ENABLE_FTL_JIT: "ON" }),
       CMAKE_EXPORT_COMPILE_COMMANDS: "ON",
       USE_BUN_JSC_ADDITIONS: "ON",
       USE_BUN_EVENT_LOOP: "ON",
