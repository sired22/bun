 }
 
+#if ENABLE(SAMPLING_PROFILER)
+
 void startCPUProfiler(JSC::VM& vm)
 {
     // Capture the wall clock time when profiling starts (before creating stopwatch)
@@ -928,6 +930,30 @@ void stopCPUProfiler(JSC::VM& vm, WTF::String* outJSON, WTF::String* outText)
     }
 }
 
+#else
+
+// SamplingProfiler isn't compiled into this build (e.g. the CLoop/JIT-less
+// configuration, which WebKit's own CMake requires disabling alongside
+// ENABLE_C_LOOP — see docs/DECISIONS.md in the bun-penryn-port handoff
+// package). Mirror the existing graceful "no profiler" handling these
+// functions already had for the !profiler case, rather than silently
+// claiming success.
+
+void startCPUProfiler(JSC::VM&)
+{
+    // Intentionally a no-op: nothing to start.
+}
+
+void stopCPUProfiler(JSC::VM&, WTF::String* outJSON, WTF::String* outText)
+{
+    if (outJSON)
+        *outJSON = WTF::String();
+    if (outText)
+        *outText = WTF::String();
+}
+
+#endif // ENABLE(SAMPLING_PROFILER)
+
 } // namespace Bun
 
